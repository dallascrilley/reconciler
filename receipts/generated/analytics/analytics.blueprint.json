{
  "name": "Analytics Recreation Canary",
  "appType": "analytics",
  "capabilities": [
    "schema-validated-actions",
    "dashboard-config-model",
    "data-dictionary-context",
    "staged-data-query",
    "provider-contract",
    "request-context"
  ],
  "frontend": "react-router",
  "server": "h3",
  "storage": "sqlite",
  "verification": {
    "typecheck": true
  },
  "requiredAssets": [
    "pattern:action",
    "pattern:dashboard-config",
    "pattern:data-dictionary",
    "primitive:staged-dataset-query",
    "pattern:provider-escape-hatch",
    "pattern:request-context"
  ],
  "composition": {
    "packageName": "analytics-recreation-canary",
    "rootRoute": "/dashboard",
    "domainActions": [
      {
        "id": "load-dashboard",
        "description": "Load dashboard rows for the composed Analytics screen.",
        "readOnly": true
      },
      {
        "id": "refresh-dashboard-query",
        "description": "Refresh the staged dashboard query.",
        "readOnly": false
      }
    ],
    "routes": [
      {
        "path": "/_index",
        "kind": "index",
        "purpose": "Analytics home redirect stub"
      },
      {
        "path": "dashboard",
        "kind": "route",
        "purpose": "Analytics chart-rendering shadcn screen"
      }
    ]
  },
  "missingCapabilities": [],
  "acceptance": {
    "target": "analytics",
    "stages": [
      {
        "stage": "L0",
        "requirement": "Scaffold installs and typechecks with zero @agent-native/core imports and app-base as the runtime dependency."
      },
      {
        "stage": "L1",
        "requirement": "SSR boots and serves the analytics route."
      },
      {
        "stage": "L2",
        "requirement": "Analytics actions register and execute through the copy-first action kernel."
      },
      {
        "stage": "L3",
        "requirement": "Analytics route -> action -> result renders one chart-rendering shadcn screen and refresh flow."
      }
    ]
  }
}
